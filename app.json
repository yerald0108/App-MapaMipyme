{
  "expo": {
    "name": "MiPyME Map",
    "slug": "mipyme-map",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mipymemap",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mipymemap.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a56db"
      },
      "package": "com.mipymemap.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1d677ae3-7f9f-4125-896f-87428b239bff"
      }
    },
    "owner": "yeralfuste"
  }
}
